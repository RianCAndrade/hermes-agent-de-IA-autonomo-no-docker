# =========================================================
# HERMES AGENT — VARIÁVEIS PRINCIPAIS
# =========================================================

# UID e GID do usuário host (para permissões corretas nos volumes)
# No Linux/WSL2: rode "id -u" e "id -g" para descobrir
# No Windows com Docker Desktop: use 1000
HERMES_UID=1000
HERMES_GID=1000

# Telegram BotFather token
TELEGRAM_BOT_TOKEN=COLE_AQUI_O_TOKEN_DO_BOTFATHER

# Seu Telegram ID numérico obtido no @userinfobot
TELEGRAM_ALLOWED_USERS=COLE_AQUI_SEU_TELEGRAM_USER_ID

# NÃO use isto com acesso a terminal, a não ser que saiba exatamente o que está fazendo.
# GATEWAY_ALLOW_ALL_USERS=true

# =========================================================
# PROVEDOR DE IA
# Preencha o que você for usar.
# =========================================================

# OpenAI
# OPENAI_API_KEY=sk-...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# =========================================================
# CONFIGURAÇÕES OPCIONAIS
# =========================================================

# Evite YOLO no começo.
# HERMES_YOLO_MODE=0
